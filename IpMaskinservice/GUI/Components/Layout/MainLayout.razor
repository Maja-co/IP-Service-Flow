@inherits LayoutComponentBase
<div class="page">
    <header class="top-row px-4">
        <div class="d-flex gap-3 w-100 justify-content-between align-items-center">
            <div class="d-flex gap-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Service</NavLink>
                <NavLink class="nav-link" href="kunder">Kunder</NavLink>
            </div>
            <NavLink class="nav-link" href="medarbejdere">Medarbejdere</NavLink>
