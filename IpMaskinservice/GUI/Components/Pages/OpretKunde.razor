@page "/opretkunde"
@rendermode InteractiveServer
@using Data_Access_Layer.Models
@using Business_Logic_Layer.Services
@inject KundeService KundeService
@inject NavigationManager NavigationManager

<PageTitle>Opret Kunde</PageTitle>

<h1>Opret ny kunde</h1>

@if (!string.IsNullOrEmpty(fejlBesked))
{
    <div class="alert alert-danger">@fejlBesked</div>
}

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label class="form-label">Firmanavn:</label>
            <input class="form-control" @bind="firmaNavn" />
        </div>
        <div class="mb-3">
            <label class="form-label">CVR-nummer (8 cifre):</label>
            <input type="number" class="form-control" @bind="cvrNummer" />
        </div>
        <div class="mb-3">
            <label class="form-label">Adresse:</label>
            <input class="form-control" @bind="adresse" />
        </div>
        <div class="mb-3">
            <label class="form-label">Kontaktperson:</label>
            <input class="form-control" @bind="kontaktPersonNavn" />
        </div>
        <div class="mb-3">
            <label class="form-label">Telefonnummer:</label>
            <input class="form-control" @bind="kontaktPersonTelefonnummer" />
        </div>
        <div class="mb-3">
            <label class="form-label">Email:</label>
            <input class="form-control" @bind="mailAdresse" />
        </div>
        
        <button class="btn btn-success" @onclick="GemKunde">Opret</button>
        <button class="btn btn-secondary" @onclick="Annuller">Annuller</button>
    </div>
</div>

@code {
    private string firmaNavn = "";
    private string adresse = "";
    private string kontaktPersonNavn = "";
    private string kontaktPersonTelefonnummer = "";
    private string mailAdresse = "";
    private int cvrNummer;
    
    private string fejlBesked = "";

    private void GemKunde()
    {
        try
        {
            // Validering klares af Kunde-konstruktøren
            var nyKunde = new Kunde(firmaNavn, adresse, kontaktPersonNavn, kontaktPersonTelefonnummer, mailAdresse, true, cvrNummer);
            KundeService.GemNyKunde(nyKunde);
            NavigationManager.NavigateTo("/kunder");
        }
        catch (ArgumentException ex)
        {
            fejlBesked = ex.Message;
        }
        catch (Exception)
        {
            fejlBesked = "Der opstod en uventet fejl ved oprettelse af kunden.";
        }
    }

    private void Annuller() => NavigationManager.NavigateTo("/kunder");
}