@page "/kunder"
@rendermode InteractiveServer
@using Data_Access_Layer.Models
@using Business_Logic_Layer.Services
@using Microsoft.EntityFrameworkCore
@inject KundeService KundeService
@inject NavigationManager NavigationManager
@inject Data_Access_Layer.MaskinContext db
@implements IDisposable

<PageTitle>Kunder</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
	<h1>Kundeoversigt</h1>
	<button class="btn btn-primary" @onclick="OpretNyKunde">Opret ny kunde</button>
</div>
<div class="mb-3">
	<label>
		<input type="checkbox" @onchange="ToggleVisInaktive" /> Vis deaktiverede kunder
	</label>
</div>

@if (kunder == null)
{
	<p><em>Henter data...</em></p>
}
else
{
	<table class="table">
		<thead>
			<tr>
				<th style="width: 20px;"></th>
				<th>Firma</th>
				<th>CVR</th>
				<th>Handlinger</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var kunde in kunder)
			{
				<tr>
					<td>
						<button class="btn btn-sm" @onclick="() => ToggleKunde(kunde.Id)">
							@(udfoldedeKunder.Contains(kunde.Id) ? "▼" : "▶")
						</button>
					</td>
					<td>
						<a href="javascript:void(0)" @onclick="() => SeKunde(kunde.Id)" style="font-weight:bold;">
							@kunde.FirmaNavn
						</a>
					</td>
					<td>@kunde.CvrNummer</td>
					<td>
						@if (kunde.ErAktiv)
						{
							<button class="btn btn-outline-danger btn-sm" @onclick="() => Deaktiver(kunde.Id)">Deaktiver</button>
						}
						else
						{
							<button class="btn btn-outline-success btn-sm" @onclick="() => Aktiver(kunde.Id)">Aktiver</button>
						}
					</td>
				</tr>
				@if (udfoldedeKunder.Contains(kunde.Id))
				{
					<tr class="table-light">
						<td colspan="4">
							<div class="ps-5">
								<strong>Maskiner:</strong>
								@if (kunde.MaskineListe != null && kunde.MaskineListe.Any())
								{
									<ul>
										@foreach (var m in kunde.MaskineListe)
										{
											<li>@m.Producent (@m.MaskineType) - S/N: @m.SerieNummer</li>
										}
									</ul>
								}
								else
								{

									<span> Ingen maskiner registreret.</span>
								}
							</div>
						</td>
					</tr>
				}
			}
		</tbody>
	</table>
}

@code {
	private List<Kunde>? kunder;
	private HashSet<int> udfoldedeKunder = new();

	protected override void OnInitialized() => Indlæs();

	private void ToggleKunde(int id)
	{
		if (udfoldedeKunder.Contains(id)) udfoldedeKunder.Remove(id);
		else udfoldedeKunder.Add(id);
	}

	private void SeKunde(int id) => NavigationManager.NavigateTo($"/kunde/{id}");

	private void Deaktiver(int id)
	{
		KundeService.DeaktiverKunde(id);
		Indlæs();
	}
	private void OpretNyKunde() => NavigationManager.NavigateTo("/opretkunde");

	private bool visInaktive = false;

	private void Indlæs()
	{
		kunder = visInaktive ? KundeService.GetDeaktiveredeKunder() : KundeService.GetAktiveKunder();
	}

	private void ToggleVisInaktive(ChangeEventArgs e)
	{
		visInaktive = (bool)e.Value;
		Indlæs();
	}

	private void Aktiver(int id)
	{
		KundeService.AktiverKunde(id);
		Indlæs();
	}
}