@page "/opretservice"
@page "/opretservice/{KundeId:int}/{MaskineId:int}"
@rendermode InteractiveServer
@using Business_Logic_Layer.Extensions
@using Business_Logic_Layer.Services
@using Data_Access_Layer.Models
@inject NavigationManager NavManager
@inject ServiceOpgaveService ServiceOpgaveService

<div class="container mt-4">
    <h1>Opret ny serviceopgave</h1>
    <hr/>

    @if (!string.IsNullOrEmpty(ErrorMessage)) {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Fejl!</strong> @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = null" aria-label="Close"></button>
        </div>
    }

    <EditForm Model="ServiceOpgaveService" OnSubmit="GemServiceopgave" FormName="opretservice">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Firma (Kunde)</label>
                <InputSelect Value="ServiceOpgaveService.ValgtKundeId"
                             ValueExpression="() => ServiceOpgaveService.ValgtKundeId"
                             ValueChanged="(int? val) => OnKundeValgt(val)"
                             class="form-select">
                    <option value="">-- Vælg kunde --</option>
                    @foreach (var kunde in ServiceOpgaveService.KunderListe) {
                        <option value="@kunde.Id">@kunde.FirmaNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Maskine</label>
                <InputSelect @bind-Value="ServiceOpgaveService.ValgtMaskineId" class="form-select">
                    <option value="">-- Vælg maskine --</option>
                    @foreach (var maskine in ServiceOpgaveService.MaskineListe) {
                        <option value="@maskine.Id">@maskine.Producent - @maskine.SerieNummer</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Kategori</label>
                <InputSelect @bind-Value="ServiceOpgaveService.ValgtKategori" class="form-select border-primary">
                    <option value="">-- Vælg kategori --</option>
                    <option value="Sikkerhedseftersyn">Sikkerhedseftersyn</option>
                    <option value="Service">Service</option>
                </InputSelect>
            </div>

            <div class="col-md-6">
                @if (ServiceOpgaveService.ValgtKategori == "Sikkerhedseftersyn") {
                    <label class="form-label border-start border-warning ps-2 text-warning">Eftersynsregel</label>
                    <InputSelect @bind-Value="ServiceOpgaveService.ValgtEftersynsRegelId" class="form-select border-warning">
                        <option value="">-- Vælg regel --</option>
                        @foreach (var regel in ServiceOpgaveService.EftersynsReglerListe) {
                            <option value="@regel.Id">@regel.Regel</option>
                        }
                    </InputSelect>
                }
                else if (ServiceOpgaveService.ValgtKategori == "Service") {
                    <div class="d-flex flex-column gap-2">
                        <div>
                            <label class="form-label">Servicetype</label>
                            <InputSelect @bind-Value="ServiceOpgaveService.ValgtServiceType" class="form-select">
                                <option value="">-- Vælg servicetype --</option>
                                @foreach (var type in ServiceOpgaveService.ServiceTyper) {
                                    <option value="@type">@type.ToString()</option>
                                }
                            </InputSelect>
                        </div>
                        <div>
                            <label class="form-label">Opgavetype</label>
                            <InputSelect @bind-Value="ServiceOpgaveService.ValgtOpgaveTypeId" class="form-select">
                                <option value="">-- Vælg opgavetype --</option>
                                @foreach (var type in ServiceOpgaveService.OpgaveTyperListe) {
                                    <option value="@type.Id">@type.OpgaveBeskrivelse</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <label class="form-label">Deadline</label>
                <InputDate @bind-Value="ServiceOpgaveService.Deadline" class="form-control"/>
            </div>

            <div class="col-md-6">
                <label class="form-label">Interval</label>
                <InputSelect @bind-Value="ServiceOpgaveService.ValgtInterval" class="form-select">
                    <option value="">-- Vælg interval --</option>
                    @foreach (var interval in ServiceOpgaveService.ServiceIntervaller) {
                        <option value="@interval">@interval.TilDansk()</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Servicetekniker (Valgfri)</label>
                <InputSelect @bind-Value="ServiceOpgaveService.ValgtTeknikerId" class="form-select">
                    <option value="">-- Vælg tekniker --</option>
                    @foreach (var tekniker in ServiceOpgaveService.TeknikerListe) {
                        <option value="@tekniker.Id">@tekniker.TeknikkerNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Ansvarlig medarbejder</label>
                <InputSelect @bind-Value="ServiceOpgaveService.ValgtMedarbejderId" class="form-select">
                    <option value="">-- Vælg medarbejder --</option>
                    @foreach (var medarbejder in ServiceOpgaveService.MedarbejderListe) {
                        <option value="@medarbejder.Id">@medarbejder.MedarbejderNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-12 mt-4">
                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Materialeliste (Valgfri)</h6>
                    </div>
                    <div class="card-body">
                        @if (!ServiceOpgaveService.Materialer.Any()) {
                            <p class="text-muted fst-italic">Ingen materialer tilføjet endnu.</p>
                        }
                        else {
                            <ul class="list-group mb-3">
                                @foreach (var (materiale, index) in ServiceOpgaveService.Materialer.Select((m, i) => (m, i))) {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@materiale</span>
                                        <button type="button" class="btn btn-outline-danger btn-sm"
                                                @onclick="() => ServiceOpgaveService.FjernMateriale(index)">
                                            Fjern
                                        </button>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="d-flex mt-2 materiale-input-gruppe">
                            <InputText @bind-Value="ServiceOpgaveService.NytMateriale"
                                       class="form-control me-2 materiale-input"
                                       placeholder="Skriv et materiale her..."/>
                            <button type="button" class="btn btn-primary materiale-knap" @onclick="ServiceOpgaveService.TilføjMateriale">
                                Tilføj til listen
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mt-4">
                <label class="form-label">Note (Valgfri)</label>
                <InputTextArea @bind-Value="ServiceOpgaveService.Note" class="form-control" rows="6"
                               placeholder="Andet vigtigt til opgaven..."/>
            </div>

            <div class="col-12 mt-4 mb-5 d-flex gap-2 justify-content-between">
                <button type="button" class="btn btn-secondary" @onclick='() => NavManager.NavigateTo("/")'>Tilbage</button>
                <button type="submit" class="btn btn-primary">Gem serviceopgave</button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? KundeId { get; set; }
    [Parameter] public int? MaskineId { get; set; }

    private string? ErrorMessage;

    protected override async Task OnInitializedAsync() {
        await ServiceOpgaveService.InitializeStateAsync(KundeId, MaskineId);
    }

    private async Task OnKundeValgt(int? kundeId) {
        await ServiceOpgaveService.KundeValgtAsync(kundeId);
    }

    private async Task GemServiceopgave() {
        ErrorMessage = null;
        
        // Simpel validering for at fange brugeren hurtigt
        if (!ServiceOpgaveService.ValgtKundeId.HasValue) {
            ErrorMessage = "Et firma skal vælges."; return;
        }
        if (string.IsNullOrEmpty(ServiceOpgaveService.ValgtKategori)) {
            ErrorMessage = "En kategori skal vælges."; return;
        }

        try {
            await ServiceOpgaveService.OpretOpgaveFraUiAsync(
                ServiceOpgaveService.ValgtKategori, ServiceOpgaveService.ValgtMaskineId, ServiceOpgaveService.Deadline, ServiceOpgaveService.ValgtInterval,
                ServiceOpgaveService.Note, ServiceOpgaveService.ValgtTeknikerId, ServiceOpgaveService.ValgtMedarbejderId,
                ServiceOpgaveService.ValgtEftersynsRegelId, ServiceOpgaveService.ValgtServiceType, ServiceOpgaveService.ValgtOpgaveTypeId, ServiceOpgaveService.Materialer);
            
            // Husk at rydde op i state, så formen er tom næste gang vi besøger den
            ServiceOpgaveService.NulstilState();
            NavManager.NavigateTo("/");
        }
        catch (Exception ex) {
            ErrorMessage = ex.Message;
        }
    }
}