@page "/opretservice"
@page "/opretservice/{KundeId:int}/{MaskineId:int}"
@rendermode InteractiveServer
@using Business_Logic_Layer.Extensions
@using Business_Logic_Layer.Services
@using Data_Access_Layer.Models
@inject NavigationManager NavManager
@inject ServiceOpgaveService ServiceOpgaveService

<div class="container mt-4">
    <h1>Opret ny serviceopgave</h1>
    <hr/>

    @if (!string.IsNullOrEmpty(ErrorMessage)) {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Fejl!</strong> @ErrorMessage
            <button type="button" class="btn-close" @onclick="() => ErrorMessage = null" aria-label="Close"></button>
        </div>
    }

    <EditForm Model="dummyModel" OnValidSubmit="GemServiceopgave" FormName="opretservice">
        <DataAnnotationsValidator/>
        <ValidationSummary class="text-danger"/>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Firma (Kunde)</label>
                <InputSelect Value="ValgtKundeId"
                             ValueExpression="() => ValgtKundeId"
                             ValueChanged="(int? val) => OnKundeValgt(val)"
                             class="form-select">
                    <option value="">-- Vælg kunde --</option>
                    @foreach (var kunde in KunderListe) {
                        <option value="@kunde.Id">@kunde.FirmaNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Maskine</label>
                <InputSelect @bind-Value="ValgtMaskineId" class="form-select">
                    <option value="">-- Vælg maskine --</option>
                    @foreach (var maskine in MaskineListe) {
                        <option value="@maskine.Id">@maskine.Producent - @maskine.SerieNummer</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Kategori</label>
                <InputSelect @bind-Value="ValgtKategori" class="form-select border-primary">
                    <option value="">-- Vælg kategori --</option>
                    <option value="Sikkerhedseftersyn">Sikkerhedseftersyn</option>
                    <option value="Service">Service</option>
                </InputSelect>
            </div>

            <div class="col-md-6">
                @if (ValgtKategori == "Sikkerhedseftersyn") {
                    <label class="form-label border-start border-warning ps-2 text-warning">Eftersynsregel</label>
                    <InputSelect @bind-Value="ValgtEftersynsRegelId" class="form-select border-warning">
                        <option value="">-- Vælg regel --</option>
                        @foreach (var regel in EftersynsReglerListe) {
                            <option value="@regel.Id">@regel.Regel</option>
                        }
                    </InputSelect>
                }
                else if (ValgtKategori == "Service") {
                    <div class="d-flex flex-column gap-2">
                        <div>
                            <label class="form-label">Servicetype</label>
                            <InputSelect @bind-Value="ValgtServiceType" class="form-select">
                                <option value="">-- Vælg servicetype --</option>
                                @foreach (var type in ServiceTyper) {
                                    <option value="@type">@type.ToString()</option>
                                }
                            </InputSelect>
                        </div>
                        <div>
                            <label class="form-label">Opgavetype</label>
                            <InputSelect @bind-Value="ValgtOpgaveTypeId" class="form-select">
                                <option value="">-- Vælg opgavetype --</option>
                                @foreach (var type in OpgaveTyperListe) {
                                    <option value="@type.Id">@type.OpgaveBeskrivelse</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <label class="form-label">Deadline</label>
                <InputDate @bind-Value="Deadline" class="form-control"/>
            </div>

            <div class="col-md-6">
                <label class="form-label">Interval</label>
                <InputSelect @bind-Value="ValgtInterval" class="form-select">
                    <option value="">-- Vælg interval --</option>
                    @foreach (var interval in ServiceIntervaller) {
                        <option value="@interval">@interval.TilDansk()</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Servicetekniker (Valgfri)</label>
                <InputSelect @bind-Value="ValgtTeknikerId" class="form-select">
                    <option value="">-- Vælg tekniker --</option>
                    @foreach (var tekniker in TeknikerListe) {
                        <option value="@tekniker.Id">@tekniker.TeknikkerNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label class="form-label">Ansvarlig medarbejder</label>
                <InputSelect @bind-Value="ValgtMedarbejderId" class="form-select">
                    <option value="">-- Vælg medarbejder --</option>
                    @foreach (var medarbejder in MedarbejderListe) {
                        <option value="@medarbejder.Id">@medarbejder.MedarbejderNavn</option>
                    }
                </InputSelect>
            </div>

            <div class="col-12 mt-4">
                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Materialeliste (Valgfri)</h6>
                    </div>
                    <div class="card-body">
                        @if (!Materialer.Any()) {
                            <p class="text-muted fst-italic">Ingen materialer tilføjet endnu.</p>
                        }
                        else {
                            <ul class="list-group mb-3">
                                @foreach (var (materiale, index) in Materialer.Select((m, i) => (m, i))) {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@materiale</span>
                                        <button type="button" class="btn btn-outline-danger btn-sm"
                                                @onclick="() => FjernMateriale(index)">
                                            Fjern
                                        </button>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="d-flex mt-2 materiale-input-gruppe">
                            <InputText @bind-Value="NytMateriale"
                                       class="form-control me-2 materiale-input"
                                       placeholder="Skriv et materiale her..."/>
                            <button type="button" class="btn btn-primary materiale-knap" @onclick="TilfojMateriale">
                                Tilføj til listen
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 mt-4">
                <label class="form-label">Note (Valgfri)</label>
                <InputTextArea @bind-Value="Note" class="form-control" rows="6"
                               placeholder="Andet vigtigt til opgaven..."/>
            </div>

            <div class="col-12 mt-4 mb-5 d-flex gap-2 justify-content-between">
                <button type="button" class="btn btn-secondary" @onclick="GaaTilbage">Tilbage</button>
                <button type="submit" class="btn btn-primary">Gem serviceopgave</button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? KundeId { get; set; }
    [Parameter] public int? MaskineId { get; set; }

    private object dummyModel = new();
    private string? ErrorMessage;

    // UI-variable
    private int? ValgtKundeId;
    private int? ValgtMaskineId;
    private string ValgtKategori = "";
    private int? ValgtEftersynsRegelId;
    private ServiceType? ValgtServiceType;
    private int? ValgtOpgaveTypeId;
    private DateTime Deadline = DateTime.Now.AddMonths(1);
    private ServiceInterval? ValgtInterval;
    private int? ValgtTeknikerId;
    private string? ValgtMedarbejderId;
    private string Note = "";
    private List<string> Materialer = new();
    private string NytMateriale = "";

    // Lister
    private List<Kunde> KunderListe = new();
    private List<Maskine> MaskineListe = new();
    private List<EftersynsRegel> EftersynsReglerListe = new();
    private List<OpgaveType> OpgaveTyperListe = new();
    private List<ServiceType> ServiceTyper = new();
    private List<ServiceInterval> ServiceIntervaller = new();
    private List<ServiceTeknikker> TeknikerListe = new();
    private List<Medarbejder> MedarbejderListe = new();
    

    protected override async Task OnInitializedAsync()
    {
        KunderListe = await ServiceOpgaveService.GetAlleKunderAsync();
        EftersynsReglerListe = await ServiceOpgaveService.GetEftersynsReglerAsync();
        OpgaveTyperListe = await ServiceOpgaveService.GetOpgaveTyperAsync();
        ServiceTyper = ServiceOpgaveService.GetServiceTyper();
        ServiceIntervaller = ServiceOpgaveService.GetServiceIntervaller();
        TeknikerListe = await ServiceOpgaveService.GetAlleTeknikereAsync();
        MedarbejderListe = await ServiceOpgaveService.GetAlleMedarbejdereAsync();
        
        if (KundeId.HasValue)
        {
            ValgtKundeId = KundeId.Value;
            MaskineListe = await ServiceOpgaveService.GetMaskinerByKundeIdAsync(KundeId.Value);

            if (MaskineId.HasValue)
                ValgtMaskineId = MaskineId.Value;
        }
    }

    private async Task OnKundeValgt(int? kundeId) {
        ValgtKundeId = kundeId;
        ValgtMaskineId = null;
        MaskineListe = kundeId.HasValue ? await ServiceOpgaveService.GetMaskinerByKundeIdAsync(kundeId.Value) : new();
    }

    private async Task GemServiceopgave() {
        ErrorMessage = null;

        // Manuel validering
        if (!ValgtKundeId.HasValue) {
            ErrorMessage = "Et Firma (Kunde) skal vælges.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ValgtKategori)) {
            ErrorMessage = "Vælg kategori.";
            return;
        }

        try {
            await ServiceOpgaveService.OpretOpgaveFraUIAsync(
                ValgtKategori,
                ValgtMaskineId,
                Deadline,
                ValgtInterval,
                Note,
                ValgtTeknikerId,
                ValgtMedarbejderId,
                ValgtEftersynsRegelId,
                ValgtServiceType,
                ValgtOpgaveTypeId,
                Materialer
            );

            NavManager.NavigateTo("/");
        }
        catch (Exception ex) {
            ErrorMessage = ex.Message;
        }
    }

    private void TilfojMateriale() {
        if (!string.IsNullOrWhiteSpace(NytMateriale)) {
            Materialer.Add(NytMateriale.Trim());
            NytMateriale = "";
        }
    }

    private void FjernMateriale(int index) => Materialer.RemoveAt(index);
    private void GaaTilbage() => NavManager.NavigateTo("/");
}